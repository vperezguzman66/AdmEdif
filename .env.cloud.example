# ==================================
# AdmEdif - Modo sin Docker (Cloud)
# ==================================
APP_ENV=development

# ---------- Base de datos (PostgreSQL gestionado) ----------
# Ejemplos: Neon, Supabase, Azure Database for PostgreSQL, Render
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/admedif?sslmode=require

# ---------- Cache/colas (Redis gestionado) ----------
# Ejemplos: Upstash, Redis Cloud, Azure Cache for Redis
REDIS_URL=rediss://default:PASSWORD@HOST:6380

# ---------- Object storage (S3 compatible) ----------
# Ejemplos: Cloudflare R2, AWS S3, Backblaze B2 S3, MinIO remoto
S3_ENDPOINT=https://YOUR-S3-ENDPOINT
S3_REGION=auto
S3_BUCKET=admedif-documents-dev
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_FORCE_PATH_STYLE=true

# ---------- Email sandbox/proveedor ----------
# Ejemplos: Mailtrap, Resend, SendGrid
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=no-reply@admedif.local

# ---------- Observabilidad ----------
# Usa al menos uno: Sentry o Grafana Cloud
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---------- Seguridad ----------
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
ENCRYPTION_KEY=CHANGE_ME_MIN_32_CHARS

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:3000
